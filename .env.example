# --- CONFIGURACIÓN PARA DOCKER (PRODUCCIÓN) ---

# Base de Datos (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=admin123
DB_NAME=gsc_db

# Backend (NestJS)
JWT_SECRET=super-secret-key-123
PORT=3000

# Frontend (Vite)
# Si usas el proxy de Nginx (recomendado), usa /api
VITE_API_URL=/api
VITE_DATABASE_MODE=nestjs

# Supabase (Opcional, si el backend lo requiere)
VITE_SUPABASE_URL=https://tu-url.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key
