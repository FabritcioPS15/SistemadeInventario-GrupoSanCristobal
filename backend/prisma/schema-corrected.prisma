generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- CORE: USUARIOS Y SEDES ---

model User {
  id            String    @id @default(uuid())
  full_name     String
  email         String    @unique
  role          String    @default("user") // 'super_admin', 'gerencia', 'sistemas', 'supervisores', 'administradores', 'personalizado'
  location_id   String?
  phone         String?
  status        String    @default("active") // 'active', 'inactive'
  notes         String?
  password      String?
  dni           String?
  permissions   String[]  @default([])
  avatar_url    String?
  
  // Relaciones
  location      Location? @relation(fields: [location_id], references: [id])
  tickets_requested Ticket[] @relation("Requester")
  tickets_assigned  Ticket[] @relation("AssignedTo")
  ticket_comments   TicketComment[]
  audit_logs        AuditLog[]
  messages_sent     Message[]
  conversations     ConversationParticipant[]
  checklists_created Checklist[] @relation("CreatedBy")
  sutran_visits_created SutranVisit[] @relation("CreatedBy")
  
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

model Location {
  id            String   @id @default(uuid())
  name          String
  type          String   // 'revision', 'escuela_conductores', 'policlinico', 'central', 'circuito'
  address       String?
  notes         String?
  region        String   @default("lima")
  checklist_url String?
  history_url   String?
  
  // Relaciones
  users         User[]
  assets        Asset[]
  areas         Area[]
  tickets       Ticket[]
  sutran_visits SutranVisit[]
  branch_audits BranchAudit[]
  cameras       Camera[]
  maintenance   MaintenanceRecord[]
  shipments_from Shipment[] @relation("FromLocation")
  shipments_to   Shipment[] @relation("ToLocation")
  checklists    Checklist[]
  servers       Server[]
  vehicles      Vehicle[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("locations")
}

model Area {
  id          String   @id @default(uuid())
  location_id String
  name        String
  description String?
  
  // Relaciones
  location    Location @relation(fields: [location_id], references: [id])
  assets      Asset[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("areas")
}

// --- INVENTARIO ---

model AssetType {
  id   String @id @default(uuid())
  name String @unique

  assets Asset[]

  created_at DateTime @default(now())

  @@map("asset_types")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?

  assets      Asset[]
  subcategories Subcategory[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("categories")
}

model Subcategory {
  id          String   @id @default(uuid())
  category_id String
  name        String
  description String?

  category    Category @relation(fields: [category_id], references: [id])
  assets      Asset[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("subcategories")
}

model Asset {
  id             String    @id @default(uuid())
  asset_type_id  String
  location_id    String?
  area_id        String?
  category_id    String?
  subcategory_id String?
  codigo_unico   String?   @unique

  // Información básica
  brand          String?
  model          String?
  serial_number  String?
  anydesk_id     String?
  ip_address     String?
  phone_number   String?
  camera_url     String?
  camera_username String?
  camera_password String?
  capacity       String?
  status         String    @default("active") // 'active', 'inactive', 'maintenance', 'extracted'
  notes          String?

  // Campos adicionales específicos
  item           String?
  descripcion    String?
  unidad_medida  String?
  cantidad       Int       @default(1)
  condicion      String?
  color          String?
  gama           String?
  fecha_adquisicion DateTime?
  valor_estimado Float     @default(0)
  estado_uso     String?
  processor      String?
  ram            String?
  operating_system String?
  bios_mode      String?
  area           String?
  placa          String?
  name           String?
  url            String?
  username       String?
  password       String?
  port           String?
  access_type    String? // 'url', 'ivms', 'esviz'
  auth_code      String?
  imei           String?
  operator       String?
  data_plan      String?
  physical_condition String?
  sistema_operativo String?
  version_so     String?
  almacenamiento String?
  bateria_estado String?
  accesorios     String?
  tipo_impresion String?
  tecnologia_impresion String?
  velocidad_impresion Int?
  resolucion     String?
  tamaño_pantalla String?
  resolucion_pantalla String?
  tipo_conexion  String?
  luminosidad    Int?
  descripcion_otros String?
  categoria_otros String?
  estado_fisico_otros String?
  material_otros String?
  dimensiones_otros String?
  peso_otros     Float?
  valor_comercial_otros Float?
  proveedor_otros String?
  fecha_compra_otros DateTime?
  garantia_otros Int?
  numero_factura_otros String?

  // Relaciones
  asset_type   AssetType @relation(fields: [asset_type_id], references: [id])
  location     Location? @relation(fields: [location_id], references: [id])
  area         Area? @relation(fields: [area_id], references: [id])
  category     Category? @relation(fields: [category_id], references: [id])
  subcategory  Subcategory? @relation(fields: [subcategory_id], references: [id])
  maintenance  MaintenanceRecord[]
  shipments    Shipment[]
  movements    InventoryMovement[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("assets")
}

// --- SERVIDORES ---

model Server {
  id          String   @id @default(uuid())
  name        String
  location_id String?
  ip_address  String?
  anydesk_id  String?
  username    String?
  password    String?
  notes       String?
  
  credentials ServerCredential[]
  location    Location? @relation(fields: [location_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("servers")
}

model ServerCredential {
  id       String @id @default(uuid())
  server_id String?
  label    String
  username String?
  password String?
  notes    String?
  
  server   Server? @relation(fields: [server_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("server_credentials")
}

// --- ACCESOS MTC ---

model MtcAcceso {
  id          String   @id @default(uuid())
  name        String
  url         String
  username    String?
  password    String?
  access_type String
  notes       String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("mtc_accesos")
}

// --- TICKETS ---

model Ticket {
  id           String    @id @default(uuid())
  title        String
  description  String?
  priority     String    @default("medium") // 'low', 'medium', 'high', 'critical'
  status       String    @default("open") // 'open', 'in_progress', 'resolved', 'closed', 'archived'
  category     String    @default("other") // 'hardware', 'software', 'network', 'access', 'other'

  // Asignación
  requester_id String?
  assigned_to  String?
  location_id  String?
  attended_at  DateTime?
  resolved_at  DateTime?
  closed_at    DateTime?

  // Relaciones
  requester    User? @relation("Requester", fields: [requester_id], references: [id])
  attendant    User? @relation("AssignedTo", fields: [assigned_to], references: [id])
  location     Location? @relation(fields: [location_id], references: [id])
  assignments  TicketAssignment[]
  comments     TicketComment[]
  canned_responses TicketCannedResponse[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("tickets")
}

model TicketAssignment {
  id         String   @id @default(uuid())
  ticket_id  String
  user_id    String
  assigned_at DateTime @default(now())

  ticket Ticket @relation(fields: [ticket_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])

  @@map("ticket_assignments")
}

model TicketComment {
  id        String   @id @default(uuid())
  ticket_id String
  user_id   String?
  content   String

  ticket Ticket @relation(fields: [ticket_id], references: [id])
  user   User?   @relation(fields: [user_id], references: [id])

  created_at DateTime @default(now())

  @@map("ticket_comments")
}

model TicketCannedResponse {
  id      String   @id @default(uuid())
  title   String
  content String

  tickets Ticket[]

  created_at DateTime @default(now())

  @@map("ticket_canned_responses")
}

// --- MANTENIMIENTO ---

model MaintenanceRecord {
  id               String   @id @default(uuid())
  asset_id         String
  maintenance_type String   // 'preventive', 'corrective', 'technical_review', 'repair'
  status           String   @default("pending") // 'pending', 'in_progress', 'completed'
  description      String
  scheduled_date   DateTime?
  completed_date  DateTime?
  technician      String?
  notes            String?
  failure_cause   String?
  solution_applied String?
  work_hours      Float?
  parts_used      Json     @default("[]")
  next_maintenance_date DateTime?
  maintenance_frequency Int?
  total_cost       Float    @default(0)
  warranty_claim   Boolean  @default(false)
  warranty_details String?
  location_id      String?

  // Relaciones
  asset    Asset    @relation(fields: [asset_id], references: [id])
  location Location? @relation(fields: [location_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("maintenance_records")
}

// --- CÁMARAS ---

model Camera {
  id             String   @id @default(uuid())
  name           String
  location_id    String?
  url            String?
  username       String?
  password       String?
  ip_address     String?
  port           String?
  brand          String?
  model          String?
  status         String   @default("active") // 'active', 'inactive', 'maintenance'
  notes          String?
  auth_code      String?
  access_type    String?  @default("url") // 'url', 'ivms', 'esviz'
  display_count  Int?
  
  // Relaciones
  location     Location? @relation(fields: [location_id], references: [id])
  camera_disks CameraDisk[]
  stored_disks StoredDisk[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("cameras")
}

model CameraDisk {
  id                String   @id @default(uuid())
  camera_id         String
  disk_number       Int
  total_capacity_gb Float
  remaining_capacity_gb Float @default(0)
  used_space_gb     Float?
  disk_type         String   @default("HDD") // 'HDD', 'SSD', 'NVMe', 'Other'
  status            String   @default("active") // 'active', 'full', 'error', 'maintenance'
  notes             String?
  brand             String?
  serial_number     String?
  stored_from       DateTime?
  stored_to         DateTime?

  // Relaciones
  camera Camera @relation(fields: [camera_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("camera_disks")
}

model StoredDisk {
  id                String   @id @default(uuid())
  camera_id         String?
  brand             String?
  serial_number     String?
  disk_type         String?
  total_capacity_gb Float?
  used_space_gb     Float?
  remaining_capacity_gb Float?
  stored_from       DateTime?
  stored_to         DateTime?
  notes             String?
  disk_number       Int?

  // Relaciones
  camera Camera? @relation(fields: [camera_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("stored_disks")
}

// --- VEHÍCULOS ---

model Vehicle {
  id                       String   @id @default(uuid())
  placa                    String   @unique
  marca                    String
  modelo                   String
  año                      Int
  tipo_combustible          String   @default("gasolina")
  kilometraje              Float    @default(0)
  estado                   String   @default("disponible")
  fecha_ultimo_mantenimiento DateTime @default(now())
  notas                    String?
  ubicacion_actual         String?
  imagen_url               String?
  citv_emision             DateTime?
  citv_vencimiento        DateTime?
  soat_emision             DateTime?
  soat_vencimiento        DateTime?
  poliza_emision           DateTime?
  poliza_vencimiento       DateTime?
  contrato_alquiler_emision DateTime?
  contrato_alquiler_vencimiento DateTime?
  color                    String?
  image_position           String   @default("center")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("vehiculos")
}

// --- ENVÍOS Y MOVIMIENTOS ---

model Shipment {
  id               String   @id @default(uuid())
  asset_id         String
  from_location_id String?
  to_location_id   String?
  shipment_date    DateTime @default(now())
  shipped_by       String?
  received_by       String?
  tracking_number  String?
  carrier          String?
  status           String   @default("shipped") // 'shipped', 'in_transit', 'delivered', 'returned'
  notes            String?

  // Relaciones
  asset         Asset    @relation(fields: [asset_id], references: [id])
  from_location Location? @relation("FromLocation", fields: [from_location_id], references: [id])
  to_location   Location? @relation("ToLocation", fields: [to_location_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("shipments")
}

model InventoryMovement {
  id                     String   @id @default(uuid())
  asset_id               String
  type                   String
  origin_location_id     String?
  origin_area_id         String?
  destination_location_id String?
  destination_area_id    String?
  quantity               Int      @default(1)
  reason                 String?
  performed_by            String?
  movement_date          DateTime @default(now())

  // Relaciones
  asset Asset @relation(fields: [asset_id], references: [id])

  created_at DateTime @default(now())

  @@map("inventory_movements")
}

// --- SUTRAN ---

model SutranVisit {
  id               String   @id @default(uuid())
  visit_date       DateTime @default(now())
  inspector_name   String?
  inspector_email  String?
  inspector_phone  String?
  location_id      String?
  location_name    String
  visit_type       String   @default("routine") // 'programada', 'no_programada', 'de_gabinete'
  status           String   @default("pending") // 'pending', 'in_progress', 'completed', 'cancelled'
  observations     String?
  findings         String?
  recommendations  String?
  documents        Json     @default("[]")
  estimated_duration String?
  estimated_cost   Float?
  created_by       String?

  // Relaciones
  location Location? @relation(fields: [location_id], references: [id])
  creator  User?    @relation("CreatedBy", fields: [created_by], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("sutran_visits")
}

// --- AUDITORÍAS ---

model BranchAudit {
  id             String   @id @default(uuid())
  location_id    String?
  auditor_name   String
  audit_date     DateTime @default(now())
  status         String   // 'excellent', 'good', 'regular', 'critical'
  score          Int
  observations   String?
  administrator_name String?

  // Relaciones
  location Location? @relation(fields: [location_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("branch_audits")
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String?
  action      String
  entity_type String
  entity_id   String?
  details     Json?

  // Relaciones
  user User? @relation(fields: [user_id], references: [id])

  created_at DateTime @default(now())

  @@map("audit_logs")
}

// --- CHAT ---

model Conversation {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id              String   @id @default(uuid())
  conversation_id String
  user_id         String
  last_read_at    DateTime?

  conversation Conversation @relation(fields: [conversation_id], references: [id])
  user         User         @relation(fields: [user_id], references: [id])

  created_at DateTime @default(now())

  @@map("conversation_participants")
}

model Message {
  id              String   @id @default(uuid())
  conversation_id String
  sender_id       String
  content         String
  read_at         DateTime?

  conversation Conversation @relation(fields: [conversation_id], references: [id])
  sender      User         @relation(fields: [sender_id], references: [id])

  created_at DateTime @default(now())

  @@map("messages")
}

// --- CHECKLISTS ---

model Checklist {
  id              String   @id @default(uuid())
  location_id     String
  scope           String   // 'escon', 'ecsal', 'citv'
  checklist_date  DateTime @default(now())
  status          String   @default("pending") // 'pending', 'in_progress', 'completed', 'cancelled'
  file_url        String?
  day_folder_url  String?
  created_by      String?

  // Relaciones
  location Location? @relation(fields: [location_id], references: [id])
  creator  User?    @relation("CreatedBy", fields: [created_by], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("checklists")
}

model ChecklistConfig {
  id                   String   @id @default(uuid())
  location_id          String
  scope                String   // 'escon', 'ecsal', 'citv'
  base_start_url       String?
  base_history_folder_url String?
  root_folder_url      String?
  is_active            Boolean  @default(true)

  // Relaciones
  location Location @relation(fields: [location_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("checklist_configs")
}

// --- NOTIFICACIONES ---

model Notification {
  id            String   @id @default(uuid())
  type          String
  title         String
  message       String
  ticket_id     String?
  user_name     String
  location_name String?
  target_role   String
  read          Boolean  @default(false)

  created_at DateTime @default(now())

  @@map("notifications")
}
